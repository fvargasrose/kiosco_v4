# =============================================================================
# DentalKiosco — Variables de entorno (PLANTILLA)
# =============================================================================
# Copiar este archivo como `.env` y completar valores reales.
# NUNCA commitear `.env` real al repositorio.
#
# Generar secretos seguros con: bash scripts/generate-secrets.sh
# =============================================================================

# -----------------------------------------------------------------------------
# Identificación de la instalación
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_VERSION=3.0.0-alpha.1
INSTALLATION_ID=local-dev                 # único por instalación
LICENSE_KEY=DEV-LOCAL-NOLICENSE-LOCAL    # en producción viene del license server

# -----------------------------------------------------------------------------
# URLs públicas
# -----------------------------------------------------------------------------
PUBLIC_BASE_URL=http://localhost           # cambia a https://kiosco.miclinica.co en prod
API_PORT=3000                              # puerto interno del API (no expuesto)

# -----------------------------------------------------------------------------
# Base de datos PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dentalkiosco
POSTGRES_USER=dentalkiosco
POSTGRES_PASSWORD=CHANGE_ME_use_generate_secrets

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_use_generate_secrets

# -----------------------------------------------------------------------------
# JWT y cifrado
# -----------------------------------------------------------------------------
# Clave para firmar JWTs (mínimo 32 chars, generar con openssl rand -base64 32)
JWT_SECRET=CHANGE_ME_minimum_32_characters_random_base64
# Clave maestra para cifrado de tokens en BD (32 bytes en base64)
ENCRYPTION_KEY=CHANGE_ME_32_bytes_base64_encoded

# Tiempos de vida de tokens
JWT_KIOSK_TTL_DAYS=90
JWT_PATIENT_SESSION_TTL_MINUTES=10
JWT_ADMIN_SESSION_TTL_HOURS=8
OTP_TTL_MINUTES=5

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_OTP_PER_PHONE_PER_HOUR=3
RATE_LIMIT_OTP_PER_IP_PER_HOUR=10
RATE_LIMIT_OTP_PER_KIOSK_PER_HOUR=30
RATE_LIMIT_LOGIN_ATTEMPTS_BEFORE_LOCK=5
RATE_LIMIT_LOGIN_LOCKOUT_MINUTES=15

# -----------------------------------------------------------------------------
# License server (infraestructura central de ALL CREATIVE)
# -----------------------------------------------------------------------------
LICENSE_SERVER_URL=https://license.allcreative.app
LICENSE_HEARTBEAT_INTERVAL_HOURS=6
LICENSE_GRACE_PERIOD_DAYS=7
LICENSE_SHUTDOWN_PERIOD_DAYS=14

# En desarrollo local, dejar vacío y el sistema usa modo "dev-bypass"
LICENSE_DEV_MODE=true

# -----------------------------------------------------------------------------
# Wompi (cuenta de la clínica)
# -----------------------------------------------------------------------------
# Estos se guardan también cifrados en BD; aquí están solo para desarrollo
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=
WOMPI_ENVIRONMENT=sandbox                  # sandbox | production
WOMPI_API_URL=https://sandbox.wompi.co/v1

# -----------------------------------------------------------------------------
# Dentalink (cuenta de la clínica)
# -----------------------------------------------------------------------------
DENTALINK_TOKEN=
DENTALINK_API_URL=https://api.dentalink.healthatom.com

# -----------------------------------------------------------------------------
# Twilio (SMS)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# -----------------------------------------------------------------------------
# Resend (Email)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@miclinica.co
RESEND_REPLY_TO_EMAIL=soporte@miclinica.co

# -----------------------------------------------------------------------------
# Logs y observabilidad
# -----------------------------------------------------------------------------
LOG_LEVEL=info                             # trace|debug|info|warn|error|fatal
LOG_FORMAT=pretty                          # pretty | json
SENTRY_DSN=                                # opcional, capa free

# -----------------------------------------------------------------------------
# Caddy / TLS
# -----------------------------------------------------------------------------
CADDY_DOMAIN=localhost                     # cambiar a dominio real en prod
CADDY_EMAIL=admin@miclinica.co             # para Let's Encrypt

# -----------------------------------------------------------------------------
# Habeas Data
# -----------------------------------------------------------------------------
HABEAS_DATA_POLICY_VERSION=v1.0

# -----------------------------------------------------------------------------
# Feature flags UI
# -----------------------------------------------------------------------------
# Registro de pacientes nuevos desde el kiosco.
# false = oculta el botón "Regístrate aquí" y desmonta la pantalla register.
#         El endpoint POST /kiosk/register sigue respondiendo (backend intacto).
# true  = flujo de auto-registro habilitado.
FEATURE_REGISTRO=false

# -----------------------------------------------------------------------------
# Modo de desarrollo
# -----------------------------------------------------------------------------
# Si true, los servicios externos (Twilio, Resend, Wompi) se mockean
DEV_MOCK_EXTERNAL_SERVICES=true
# Si true, muestra el OTP en logs (SOLO PARA DEV, nunca en prod)
DEV_LOG_OTP=true
