{
  "name": "dentalkiosco",
  "version": "3.0.0-alpha.1",
  "description": "Sistema de kiosco dental self-hosted - ALL CREATIVE",
  "private": true,
  "license": "UNLICENSED",
  "author": "ALL CREATIVE (Dr. Hermes Vargas Rosero)",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "stack:up": "docker compose up -d",
    "stack:down": "docker compose down",
    "stack:logs": "docker compose logs -f",
    "stack:ps": "docker compose ps",
    "stack:reset": "docker compose down -v && docker compose up -d",
    "db:migrate": "cd apps/api && pnpm migrate up",
    "db:rollback": "cd apps/api && pnpm migrate down",
    "db:seed": "cd apps/api && pnpm seed",
    "secrets:generate": "bash scripts/generate-secrets.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@9.4.0"
}
