# =============================================================================
# License Server — Variables de entorno
# Copiar a .env y completar antes de arrancar.
# =============================================================================

# Servidor
PORT=3001
NODE_ENV=production
LOG_LEVEL=info
LOG_FORMAT=json

# Base de datos (PostgreSQL propio del license server)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dk_licenses
POSTGRES_USER=dk_licenses
POSTGRES_PASSWORD=CAMBIAR_EN_PRODUCCION

# Autenticación del superadministrador
# Genera con: openssl rand -hex 32
# Esta clave autentica endpoints de gestión (emitir / revocar licencias).
# Solo el proveedor (AllCreative) debe conocerla.
SUPERADMIN_API_KEY=CAMBIAR_EN_PRODUCCION_openssl_rand_hex_32
